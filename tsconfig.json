{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "allowJs": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@electron/*": [
        "electron/*"
      ],
      "@backend/*": [
        "src/backend/*"
      ],
      "@workers/*": [
        "src/workers/*"
      ],
      "@pipelines/*": [
        "src/pipelines/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ]
    }
  },
  "exclude": [
    "dist",
    "dist-electron",
    "release",
    "node_modules",
    "interview-sentiment-analyzer-main"
  ]
}
