{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": [
      "node"
    ],
    "outDir": "dist-electron",
    "rootDir": ".",
    "noEmit": false
  },
  "include": [
    "electron/**/*",
    "src/shared/**/*",
    "src/workers/**/*",
    "src/pipelines/**/*"
  ]
}
