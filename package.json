{
  "name": "interview-sentiment-analyzer",
  "version": "1.0.0",
  "description": "assist in giving candidates feedback on their interview performance",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "main": "dist-electron/electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"pnpm:dev:renderer\" \"pnpm:dev:electron\"",
    "dev:log": "concurrently -k \"pnpm:dev:renderer\" \"pnpm:dev:electron --log-level=all\"",
    "dev:renderer": "vite --port 5183",
    "dev:electron": "wait-on tcp:5183 && cross-env VITE_DEV_SERVER_URL=http://localhost:5183 electron .",
    "clean": "node -e \"const fs=require('fs'); for (const d of ['dist-electron','dist']) { try { fs.rmSync(d,{recursive:true,force:true}); } catch (e) { if (e && e.code !== 'ENOENT') throw e; } }\"",
    "build": "pnpm clean && pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node scripts/resolve-electron-path-aliases.mjs",
    "dist": "pnpm build && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm clean && pnpm build:electron && node --test dist-electron/src/backend/test/*.test.js",
    "typecheck": "tsc -p tsconfig.renderer.json --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "keywords": [
    "interview",
    "typescript",
    "javascript",
    "electron",
    "neurodiversity",
    "interview-coach"
  ],
  "author": "Chuck Peters",
  "license": "MIT",
  "dependencies": {
    "@audio/webm-decode": "^1.0.0",
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/langgraph": "^1.2.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@remixicon/react": "^4.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.1",
    "electron-updater": "^6.8.3",
    "jest": "^30.3.0",
    "mermaid": "^11.13.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "react-devtools": "^7.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.chuckpeters.interviewsentimentanalyzer",
    "productName": "Interview Sentiment Analyzer",
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json",
      "LICENSE",
      "src/**"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "extendInfo": {
        "NSAudioCaptureUsageDescription": "This app captures system audio during screen recording for interview analysis.",
        "NSMicrophoneUsageDescription": "This app uses the microphone to record interview audio for sentiment analysis."
      }
    },
    "win": {
      "target": [
        {
          "target": "msi",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Chuck_U",
        "repo": "interview-sentiment-analyzer"
      }
    ]
  }
}